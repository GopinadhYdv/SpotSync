# Ease Events environment configuration
# Copy this file to .env or .env.local and replace the placeholder values.

# Database
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Authentication
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=http://localhost:4000/api/auth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_public_key

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Application URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:4000

# Optional Create.xyz integration values
NEXT_PUBLIC_CREATE_ENV=DEVELOPMENT
NEXT_PUBLIC_CREATE_BASE_URL=https://www.create.xyz
NEXT_PUBLIC_CREATE_API_BASE_URL=
NEXT_PUBLIC_CREATE_HOST=
NEXT_PUBLIC_PROJECT_GROUP_ID=

# Runtime
NODE_ENV=development
